{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "//": "Proxy API calls to the Render backend. Replace the host after the backend deploys.",
      "source": "/api/:path*",
      "destination": "https://contract-backend-REPLACE.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
